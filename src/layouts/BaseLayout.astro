---
/**
 * 基本レイアウト
 * SEO・OGP・構造化データ・フォント読み込みを一元管理する
 */

import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = '白石百合恵 | クラリネット・ピアノレッスン｜さいたま市・東京',
  description = 'クラリネット・ピアノ奏者の白石百合恵が行う個人レッスン。初心者から上級者まで、お一人おひとりのペースに合わせた丁寧な指導。さいたま市・東京都心部対応、出張レッスンも承ります。',
  ogImage = '/ogp.jpg',
} = Astro.props;

// TODO: 公開時に実際のドメインに変更してください
const SITE_URL = 'https://yurieshiraishi.com';
const canonicalUrl = new URL(Astro.url.pathname, SITE_URL).href;
const ogImageAbsolute = `${SITE_URL}${ogImage}`;

// 構造化データ（JSON-LD）
const structuredData = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": `${SITE_URL}/#person`,
      "name": "白石 百合恵",
      "alternateName": "Yurie Shiraishi",
      "url": SITE_URL,
      "image": ogImageAbsolute,
      "jobTitle": "クラリネット・ピアノ奏者 / 講師",
      "description": "桐朋学園大学音楽学部卒業のクラリネット・ピアノ奏者。コンサート・レコーディング等の演奏活動のかたわら、クラリネット・ピアノの個人レッスンを行っている。",
      "alumniOf": {
        "@type": "CollegeOrUniversity",
        "name": "桐朋学園大学音楽学部"
      },
      "email": "clarinet.yurie@gmail.com",
      "knowsAbout": ["クラリネット", "ピアノ", "音楽教育", "クラシック音楽"],
      "sameAs": [
        "https://www.instagram.com/yreee22",
        "https://youtube.com/@yurieshiraishiclarinet"
      ]
    },
    {
      "@type": "LocalBusiness",
      "@id": `${SITE_URL}/#studio`,
      "name": "白石百合恵 クラリネット・ピアノ教室",
      "url": SITE_URL,
      "description": "クラリネット・ピアノの個人レッスン。初心者から中級者まで、お一人おひとりのペースに合わせた丁寧な指導。さいたま市・東京都心部対応。",
      "email": "clarinet.yurie@gmail.com",
      "priceRange": "¥3,000〜",
      "currenciesAccepted": "JPY",
      "areaServed": [
        { "@type": "City", "name": "さいたま市" },
        { "@type": "City", "name": "東京都" }
      ]
    }
  ]
});
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- タイトル・メタ情報 -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content="クラリネット レッスン, ピアノ レッスン, 白石百合恵, さいたま市 音楽教室, 東京 クラリネット教室, 個人レッスン, 音楽教室, クラリネット 初心者" />

  <!-- canonical -->
  <link rel="canonical" href={canonicalUrl} />

  <!-- OGP（SNSシェア用） -->
  <meta property="og:type"        content="website" />
  <meta property="og:url"         content={canonicalUrl} />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={ogImageAbsolute} />
  <meta property="og:site_name"   content="白石百合恵 クラリネット・ピアノ" />
  <meta property="og:locale"      content="ja_JP" />

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImageAbsolute} />

  <!-- ファビコン -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Google Fonts（サイト全体で使用するフォント） -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;1,500;1,600&family=Noto+Sans+JP:wght@300;400;500;700&family=Shippori+Mincho:wght@500;600;700&display=swap"
    rel="stylesheet"
  />

  <!-- 構造化データ（JSON-LD） -->
  <script type="application/ld+json" set:html={structuredData} />
</head>
<body>
  <slot />
</body>
</html>
