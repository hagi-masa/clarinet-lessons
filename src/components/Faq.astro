---
/**
 * よくあるご質問セクション
 * <details>/<summary> でJSなしのアコーディオンを実装
 */

const faqItems = [
  {
    question: 'レッスンに自分の楽器は必要ですか？',
    answer:   'ご自身の楽器をご用意いただくのが基本ですが、部活動でお使いの楽器でレッスンを受けられる方もいらっしゃいます。ご購入前のご相談も承りますので、お気軽にお問い合わせください。なお、リード・リガチャー・マウスピースは、生徒さまご自身でのご購入をお願いしております。',
  },
  {
    question: '大人の初心者でも始められますか？',
    answer:   'もちろんです。クラリネットは大人から始める方も多くいらっしゃいます。ピアノの単発レッスンは大人の趣味の方を対象に、お一人おひとりのペースで進めます。',
  },
  {
    question: 'レッスンの場所はどこですか？',
    answer:   '日進駅から徒歩15分のスタジオのほか、さいたま市・東京都心部・他要相談での出張レッスン（1時間8,000円・交通費込み）にも対応しています。',
  },
  {
    question: '都合が悪い日は振替できますか？',
    answer:   '可能な範囲で振替レッスンに対応しています。入会金もいただいておりませんので、気軽に始めていただけます。',
  },
];
---

<section class="faq-section">
  <div class="faq-inner">
    <div class="faq-header">
      <p class="sec-en">FAQ</p>
      <h2 class="faq-title">よくあるご質問</h2>
    </div>

    <dl class="faq-list">
      {faqItems.map((item, i) => (
        <div class="faq-item">
          <details class="faq-details">
            <summary class="faq-question">
              <span class="faq-q-mark" aria-hidden="true">Q.</span>
              <span class="faq-q-text">{item.question}</span>
              <span class="faq-icon" aria-hidden="true">+</span>
            </summary>
            <div class="faq-answer">
              <span class="faq-a-mark" aria-hidden="true">A.</span>
              <p>{item.answer}</p>
            </div>
          </details>
        </div>
      ))}
    </dl>
  </div>
</section>

<style>
  .faq-section {
    background: var(--cream-light);
    border-top: 1px solid var(--border-light);
    border-bottom: 1px solid var(--border-light);
  }

  .faq-inner {
    max-width: var(--max-w-text);
    margin: 0 auto;
    padding: clamp(60px, 9vw, 110px) var(--px);
  }

  .faq-header {
    text-align: center;
    margin-bottom: clamp(34px, 5vw, 48px);
  }

  .faq-title {
    font-family: var(--font-serif-ja);
    font-weight: 600;
    font-size: clamp(24px, 4vw, 36px);
    color: var(--navy);
    margin: 0;
    letter-spacing: 0.06em;
  }

  /* ── アコーディオンリスト ── */
  .faq-list {
    border-top: 1px solid var(--border);
  }

  .faq-item {
    border-bottom: 1px solid var(--border);
  }

  /* <details> リセット */
  .faq-details {
    /* marker を非表示 */
  }

  .faq-details summary::-webkit-details-marker {
    display: none;
  }

  .faq-details summary::marker {
    content: '';
  }

  /* ── 質問行 ── */
  .faq-question {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 10px;
    cursor: pointer;
    text-align: left;
    padding: 22px 4px;
    list-style: none;
    /* フォーカス表示 */
    outline-offset: 2px;
  }

  .faq-question:focus-visible {
    outline: 2px solid var(--wine);
  }

  .faq-q-mark {
    font-family: var(--font-serif-ja);
    font-weight: 600;
    color: var(--wine);
    font-size: clamp(15px, 2vw, 17px);
    flex-shrink: 0;
  }

  .faq-q-text {
    font-family: var(--font-serif-ja);
    font-weight: 600;
    font-size: clamp(15px, 2vw, 17px);
    color: var(--navy);
    line-height: 1.6;
    flex: 1;
  }

  .faq-icon {
    flex-shrink: 0;
    color: var(--wine);
    font-size: 20px;
    line-height: 1;
    transition: transform 0.25s;
    margin-left: auto;
    padding-left: 16px;
  }

  /* 開いた状態でアイコンを回転 */
  .faq-details[open] .faq-icon {
    transform: rotate(45deg);
  }

  /* ── 回答 ── */
  .faq-answer {
    display: flex;
    gap: 10px;
    padding: 0 4px 24px;
  }

  .faq-a-mark {
    font-family: var(--font-serif-ja);
    font-weight: 600;
    color: var(--wine);
    font-size: 14.5px;
    flex-shrink: 0;
    padding-top: 2px;
  }

  .faq-answer p {
    font-size: 14.5px;
    line-height: 2.05;
    color: var(--text-muted);
    margin: 0;
  }
</style>
