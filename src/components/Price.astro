---
/**
 * 料金システムセクション
 * クラリネット・学生コース・ピアノ単発・出張レッスンを表示
 */

// クラリネット個人レッスン料金プラン
const clarinetPlans = [
  {
    duration: '60分',
    plans: [
      { label: '月1回', price: '5,000', note: '' },
      { label: '月2回', price: '9,000', note: '1,000円お得' },
    ],
  },
  {
    duration: '45分',
    plans: [
      { label: '月1回', price: '4,000', note: '' },
      { label: '月2回', price: '7,000', note: '1,000円お得' },
    ],
  },
  {
    duration: '30分',
    plans: [
      { label: '月1回', price: '3,000', note: '' },
      { label: '月2回', price: '5,500', note: '500円お得' },
    ],
  },
];

// ご案内テキスト
const notes = [
  '入会金はいただいておりません。',
  '振替レッスンは、可能な範囲で対応いたします。',
  '出張レッスンでスタジオを利用する場合は、別途スタジオ代をご負担ください。',
  'ご自宅への訪問は、女性の方に限らせていただきます。',
];
---

<section id="price" class="price-section">
  <div class="price-inner">
    <div class="price-header">
      <p class="sec-en">Price</p>
      <h2 class="sec-title">料金システム</h2>
      <p class="price-note">入会金はいただきません。表示はすべて税込・月謝制です。前月末までのお支払いをお願いいたします。</p>
    </div>

    <!-- クラリネット個人レッスン -->
    <h3 class="price-category">
      <span class="category-line" aria-hidden="true"></span>クラリネット 個人レッスン
    </h3>
    <div class="clarinet-grid">
      {clarinetPlans.map(group => (
        <div class="plan-card">
          <div class="plan-duration">
            <span class="duration-num">{group.duration}</span>
          </div>
          <div class="plan-rows">
            {group.plans.map(p => (
              <div class="plan-row">
                <div class="plan-label-wrap">
                  <span class="plan-label">{p.label}</span>
                  {p.note && <span class="plan-save">{p.note}</span>}
                </div>
                <div class="plan-price">
                  <span class="price-num">{p.price}</span><span class="price-unit">円</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- 学生コース -->
    <div class="special-card">
      <div class="special-info">
        <span class="special-tag">学生限定</span>
        <h4 class="special-title">学生コース</h4>
        <p class="special-sub">クラリネット / 小学生・中学生・高校生・大学生</p>
        <p class="special-desc">部活動やコンクール対策、基礎力アップにおすすめのコースです。</p>
      </div>
      <div class="special-price-wrap">
        <span class="price-num">5,000</span><span class="price-unit">円</span>
        <span class="price-unit-sub">/ 月2回（30分）</span>
      </div>
    </div>

    <!-- ピアノ単発レッスン -->
    <h3 class="price-category price-category--mt">
      <span class="category-line" aria-hidden="true"></span>ピアノ 単発レッスン
    </h3>
    <div class="special-card">
      <div class="special-info">
        <span class="special-tag">大人の趣味の方へ</span>
        <h4 class="special-title">ピアノ レッスン</h4>
        <p class="special-sub">大人の趣味の方限定</p>
        <p class="special-desc">弾きたい曲を一曲から。お好きなタイミングでご利用いただける単発レッスンです。</p>
      </div>
      <div class="special-price-wrap">
        <span class="price-num">5,000</span><span class="price-unit">円</span>
        <span class="price-unit-sub">/ 1回（60分・単発）</span>
      </div>
    </div>

    <!-- 出張レッスン -->
    <h3 class="price-category price-category--mt">
      <span class="category-line" aria-hidden="true"></span>出張レッスン
      <span class="category-sub">（クラリネット・ピアノ共通）</span>
    </h3>
    <div class="special-card">
      <div class="special-info">
        <span class="special-tag">出張・共通</span>
        <h4 class="special-title">出張レッスン</h4>
        <p class="special-sub">対応エリア：さいたま市・東京都心部・他要相談</p>
        <p class="special-desc">ご自宅やスタジオへ伺います。クラリネット・ピアノのどちらにも対応いたします。</p>
      </div>
      <div class="special-price-wrap">
        <span class="price-num">8,000</span><span class="price-unit">円</span>
        <span class="price-unit-sub">/ 1時間（交通費込み）</span>
      </div>
    </div>

    <!-- 全コース共通のご案内 -->
    <div class="price-notes-wrap">
      <div class="notes-divider">
        <span class="notes-divider-line" aria-hidden="true"></span>
        <p class="notes-divider-label">全コース共通のご案内</p>
        <span class="notes-divider-line" aria-hidden="true"></span>
      </div>
      <div class="price-notes">
        <ul class="notes-list">
          {notes.map(note => (
            <li><span class="notes-bullet" aria-hidden="true">—</span><span>{note}</span></li>
          ))}
        </ul>
      </div>
    </div>

    <!-- 紹介キャンペーン -->
    <div class="campaign-wrap">
      <div class="campaign-divider">
        <span class="campaign-divider-line" aria-hidden="true"></span>
        <p class="campaign-divider-label">紹介キャンペーン</p>
        <span class="campaign-divider-line" aria-hidden="true"></span>
      </div>
      <div class="campaign-card">
        <div class="campaign-header">
          <span class="campaign-badge">実施中</span>
          <p class="campaign-title">ご紹介でレッスン1回分が無料に</p>
        </div>
        <p class="campaign-desc">
          在籍中の生徒さんが新しい方をご紹介くださった場合、<strong>紹介した方・紹介された方の双方に1回分のレッスンを無料</strong>で行わせていただきます。
        </p>
        <div class="campaign-benefits">
          <div class="campaign-benefit">
            <p class="benefit-role">紹介した方</p>
            <p class="benefit-detail">4カ月目のレッスン<strong>1回分が無料</strong></p>
          </div>
          <div class="campaign-benefit-divider" aria-hidden="true">＋</div>
          <div class="campaign-benefit">
            <p class="benefit-role">紹介された方</p>
            <p class="benefit-detail">4カ月目のレッスン<strong>1回分が無料</strong></p>
          </div>
        </div>
        <p class="campaign-note">※ ご紹介された方が3カ月継続された場合、4カ月目に適用となります。詳しくはお問い合わせください。</p>
      </div>
    </div>

    <div class="price-cta">
      <a href="#contact" class="btn-primary">申し込む →</a>
    </div>
  </div>
</section>

<style>
  .price-section {
    background: var(--cream-light);
    border-top: 1px solid var(--border-light);
    border-bottom: 1px solid var(--border-light);
  }

  .price-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: var(--py) var(--px);
  }

  .price-header {
    text-align: center;
    margin-bottom: clamp(38px, 5vw, 56px);
  }

  .price-note {
    font-size: 14.5px;
    color: var(--text-faint);
    letter-spacing: 0.04em;
    margin: 4px 0 0;
  }

  /* ── カテゴリ見出し ── */
  .price-category {
    font-family: var(--font-serif-ja);
    font-weight: 600;
    font-size: 18px;
    color: var(--wine);
    letter-spacing: 0.1em;
    margin: 0 0 20px;
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .price-category--mt {
    margin-top: clamp(42px, 5vw, 58px);
  }

  .category-line {
    width: 24px;
    height: 1px;
    background: var(--wine);
    flex-shrink: 0;
  }

  .category-sub {
    font-size: 12px;
    color: var(--text-light);
    font-weight: 500;
    letter-spacing: 0.04em;
  }

  /* ── クラリネット料金グリッド ── */
  .clarinet-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: clamp(16px, 2vw, 24px);
  }

  .plan-card {
    background: var(--cream);
    border: 1px solid var(--border);
    border-top: 3px solid var(--wine);
    padding: clamp(22px, 3vw, 30px);
  }

  .plan-duration {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-bottom: 18px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--border-light);
  }

  .duration-num {
    font-family: var(--font-serif-ja);
    font-weight: 600;
    font-size: 32px;
    color: var(--wine);
  }

  .duration-unit {
    font-size: 13px;
    color: var(--text-light);
  }

  .plan-rows {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .plan-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 10px;
  }

  .plan-label-wrap {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .plan-label {
    font-size: 14px;
    color: var(--text-lighter);
    font-weight: 500;
  }

  .plan-save {
    display: inline-block;
    background: var(--wine);
    color: var(--cream);
    font-size: 10.5px;
    letter-spacing: 0.06em;
    padding: 2px 7px;
  }

  /* ── 特別コード（学生・ピアノ・出張）共通 ── */
  .special-card {
    margin-top: clamp(18px, 2.5vw, 26px);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 16px 28px;
    background: var(--cream);
    border: 1px solid var(--border);
    border-left: 3px solid var(--wine);
    padding: clamp(22px, 3vw, 30px);
  }

  .special-info {
    flex: 1 1 280px;
    min-width: 240px;
  }

  .special-tag {
    display: inline-block;
    background: var(--wine);
    color: var(--cream);
    font-size: 11px;
    letter-spacing: 0.12em;
    padding: 4px 11px;
    margin-bottom: 12px;
  }

  .special-title {
    font-family: var(--font-serif-ja);
    font-weight: 600;
    font-size: 21px;
    color: var(--navy);
    margin: 0 0 4px;
  }

  .special-sub {
    font-size: 12.5px;
    color: var(--text-light);
    letter-spacing: 0.04em;
    margin: 0 0 10px;
  }

  .special-desc {
    font-size: 13.5px;
    line-height: 1.95;
    color: var(--text-muted);
    margin: 0;
  }

  .special-price-wrap {
    font-family: var(--font-serif-ja);
    color: var(--navy);
    white-space: nowrap;
    display: flex;
    align-items: baseline;
    gap: 4px;
    flex-wrap: wrap;
  }

  /* ── 価格共通 ── */
  .price-num {
    font-family: var(--font-serif-ja);
    font-size: 34px;
    font-weight: 700;
    color: var(--wine);
  }

  .special-price-wrap .price-num {
    font-size: 48px;
  }

  .price-unit {
    font-size: 15px;
    color: var(--wine);
    font-weight: 600;
  }

  .price-unit-sub {
    font-size: 12.5px;
    color: var(--text-light);
    margin-left: 4px;
  }

  /* ── 紹介キャンペーン ── */
  .campaign-wrap {
    margin-top: clamp(46px, 7vw, 70px);
  }

  /* 区切り線ラベル */
  .campaign-divider {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: clamp(18px, 2.5vw, 26px);
  }

  .campaign-divider-line {
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .campaign-divider-label {
    font-family: var(--font-serif-ja);
    font-weight: 600;
    font-size: 13.5px;
    color: var(--wine);
    letter-spacing: 0.18em;
    white-space: nowrap;
    margin: 0;
  }

  /* キャンペーンカード */
  .campaign-card {
    background: #f5eaec;
    border: 1px solid rgba(110, 42, 54, 0.22);
    padding: clamp(24px, 3.5vw, 38px);
  }

  .campaign-header {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }

  .campaign-badge {
    display: inline-block;
    background: var(--wine);
    color: #fff;
    font-size: 11px;
    letter-spacing: 0.14em;
    padding: 4px 12px;
    flex-shrink: 0;
  }

  .campaign-title {
    font-family: var(--font-serif-ja);
    font-weight: 600;
    font-size: 19px;
    color: var(--wine);
    letter-spacing: 0.06em;
    margin: 0;
  }

  .campaign-desc {
    font-size: 13.5px;
    line-height: 1.95;
    color: var(--text-muted);
    margin: 0 0 22px;
  }

  /* 特典ボックス */
  .campaign-benefits {
    display: flex;
    align-items: center;
    gap: clamp(14px, 3vw, 32px);
    flex-wrap: wrap;
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(110, 42, 54, 0.15);
    padding: clamp(18px, 2.5vw, 26px);
    margin-bottom: 16px;
  }

  .campaign-benefit {
    flex: 1 1 180px;
    text-align: center;
  }

  .benefit-role {
    font-size: 12px;
    letter-spacing: 0.1em;
    color: var(--wine);
    font-weight: 600;
    margin: 0 0 6px;
  }

  .benefit-detail {
    font-size: 14px;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
  }

  .campaign-benefit-divider {
    font-size: 20px;
    color: var(--wine);
    opacity: 0.5;
    flex-shrink: 0;
  }

  .campaign-note {
    font-size: 12px;
    color: var(--text-faint);
    letter-spacing: 0.03em;
    margin: 0;
  }

  /* ── 全コース共通のご案内 ── */
  .price-notes-wrap {
    margin-top: clamp(46px, 7vw, 70px);
  }

  /* 区切り線 + ラベル */
  .notes-divider {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: clamp(18px, 2.5vw, 26px);
  }

  .notes-divider-line {
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .notes-divider-label {
    font-family: var(--font-serif-ja);
    font-weight: 600;
    font-size: 13.5px;
    color: var(--wine);
    letter-spacing: 0.18em;
    white-space: nowrap;
    margin: 0;
  }

  .price-notes {
    background: var(--cream);
    border: 1px solid var(--border);
    padding: clamp(22px, 3vw, 30px);
  }

  .notes-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 680px;
  }

  .notes-list li {
    display: flex;
    gap: 12px;
    font-size: 13.5px;
    line-height: 1.9;
    color: var(--text-muted);
  }

  .notes-bullet {
    color: var(--wine);
    flex-shrink: 0;
  }

  /* ── CTA ── */
  .price-cta {
    text-align: center;
    margin-top: clamp(36px, 5vw, 48px);
  }

  /* ── モバイル：情報密度を高める ── */
  @media (max-width: 767px) {
    /* クラリネット3コースを横並び3列にして一覧性を確保 */
    .clarinet-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
    }

    .plan-card {
      padding: 12px 8px;
    }

    .plan-duration {
      margin-bottom: 10px;
      padding-bottom: 8px;
    }

    .duration-num {
      font-size: 18px;
    }

    .plan-rows {
      gap: 10px;
    }

    /* ラベルと料金を縦積みにしてカード幅を節約 */
    .plan-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 2px;
    }

    .plan-label {
      font-size: 10px;
    }

    .plan-save {
      font-size: 8px;
      padding: 1px 4px;
    }

    /* クラリネットグリッド内の料金数字を縮小 */
    .price-num {
      font-size: 18px;
    }

    .price-unit {
      font-size: 11px;
    }

    /* 特別カードの大きな料金数字は適度なサイズに抑える */
    .special-price-wrap .price-num {
      font-size: 32px;
    }

    .special-card {
      padding: 16px 14px;
      gap: 12px 16px;
    }

    .special-title {
      font-size: 18px;
    }

    .campaign-benefits {
      display: grid;
      grid-template-columns: 1fr;
      gap: 10px;
    }

    .campaign-benefit {
      text-align: left;
    }

    .campaign-benefit-divider {
      justify-self: start;
      font-size: 18px;
      line-height: 1;
      margin: 0;
    }
  }
</style>
