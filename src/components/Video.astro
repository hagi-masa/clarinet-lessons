---
/**
 * 演奏動画セクション
 * YouTube チャンネルへのリンクと埋め込みプレースホルダー
 *
 * TODO: 特定の動画を埋め込む場合は YOUTUBE_VIDEO_ID に YouTube 動画IDを設定してください
 *       例: 'dQw4w9WgXcQ'（URLの?v=以降の文字列）
 */

// YouTube 動画IDを設定すると動画が埋め込まれます（空文字列の場合はリンク表示）
const YOUTUBE_VIDEO_ID = '';
const YOUTUBE_CHANNEL_URL = 'https://youtube.com/@yurieshiraishiclarinet';
---

<section id="video" class="video-section">
  <div class="video-inner">
    <div class="video-header">
      <p class="sec-en">Performance</p>
      <h2 class="sec-title">演奏動画</h2>
      <p class="video-lead">実際の演奏の雰囲気を、動画でご覧いただけます。</p>
    </div>

    {YOUTUBE_VIDEO_ID ? (
      /* 動画IDが設定されている場合：レスポンシブ埋め込み */
      <div class="video-embed-wrap">
        <iframe
          src={`https://www.youtube.com/embed/${YOUTUBE_VIDEO_ID}?rel=0`}
          title="白石百合恵 演奏動画"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>
    ) : (
      /* 動画IDが未設定の場合：YouTube チャンネルへのリンク */
      <div class="video-placeholder">
        <div class="play-icon" aria-hidden="true">
          <div class="play-triangle"></div>
        </div>
        <p class="placeholder-text">演奏動画は YouTube チャンネルでご覧いただけます</p>
        <a
          href={YOUTUBE_CHANNEL_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="youtube-link btn-primary"
        >
          YouTube で演奏を見る →
        </a>
      </div>
    )}
  </div>
</section>

<style>
  .video-section {
    max-width: var(--max-w-narrow);
    margin: 0 auto;
    padding: clamp(60px, 9vw, 110px) var(--px);
  }

  .video-header {
    text-align: center;
    margin-bottom: clamp(34px, 5vw, 50px);
  }

  .video-lead {
    font-size: 15px;
    line-height: 2;
    color: var(--text-muted);
    max-width: 32em;
    margin: 0 auto;
  }

  /* ── レスポンシブ埋め込み（16:9 比率） ── */
  .video-embed-wrap {
    position: relative;
    width: 100%;
    max-width: 920px;
    margin: 0 auto;
    aspect-ratio: 16 / 9;
    border: 1px solid var(--border);
    overflow: hidden;
    background: #000;
  }

  .video-embed-wrap iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  /* ── プレースホルダー ── */
  .video-placeholder {
    position: relative;
    width: 100%;
    max-width: 920px;
    margin: 0 auto;
    aspect-ratio: 16 / 9;
    background: var(--navy-dark);
    border: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 20px;
  }

  .play-icon {
    width: 74px;
    height: 74px;
    border-radius: 50%;
    background: var(--wine);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.25);
  }

  .play-triangle {
    width: 0;
    height: 0;
    border-left: 20px solid #f6f0e3;
    border-top: 13px solid transparent;
    border-bottom: 13px solid transparent;
    margin-left: 5px;
  }

  .placeholder-text {
    font-size: 14px;
    color: #b3a48f;
    letter-spacing: 0.06em;
    margin: 0;
    text-align: center;
    padding: 0 16px;
  }

  .youtube-link {
    font-size: 14px;
    padding: 12px 24px;
  }
</style>
