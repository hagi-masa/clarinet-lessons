---
/**
 * 料金システムセクション
 * クラリネット・学生コース・ピアノ単発・出張レッスンを表示
 */

// クラリネット個人レッスン料金プラン
const clarinetPlans = [
  {
    duration: '60分',
    plans: [
      { label: '月1回', price: '5,000', note: '' },
      { label: '月2回', price: '9,000', note: '1,000円お得' },
    ],
  },
  {
    duration: '45分',
    plans: [
      { label: '月1回', price: '4,000', note: '' },
      { label: '月2回', price: '7,000', note: '1,000円お得' },
    ],
  },
  {
    duration: '30分',
    plans: [
      { label: '月1回', price: '3,000', note: '' },
      { label: '月2回', price: '5,500', note: '500円お得' },
    ],
  },
];

// ご案内テキスト
const notes = [
  '入会金はいただいておりません。',
  '振替レッスンは、可能な範囲で対応いたします。',
  '出張レッスンでスタジオを利用する場合は、別途スタジオ代をご負担ください。',
  'ご自宅への訪問は、女性の方に限らせていただきます。',
];
---

<section id="price" class="price-section">
  <div class="price-inner">
    <div class="price-header">
      <p class="sec-en">Price</p>
      <h2 class="sec-title">料金システム</h2>
      <p class="price-note">入会金はいただきません。表示はすべて税込・月謝制です。</p>
    </div>

    <!-- クラリネット個人レッスン -->
    <h3 class="price-category">
      <span class="category-line" aria-hidden="true"></span>クラリネット 個人レッスン
    </h3>
    <div class="clarinet-grid">
      {clarinetPlans.map(group => (
        <div class="plan-card">
          <div class="plan-duration">
            <span class="duration-num">{group.duration}</span>
            <span class="duration-unit">1回あたり</span>
          </div>
          <div class="plan-rows">
            {group.plans.map(p => (
              <div class="plan-row">
                <div class="plan-label-wrap">
                  <span class="plan-label">{p.label}</span>
                  {p.note && <span class="plan-save">{p.note}</span>}
                </div>
                <div class="plan-price">
                  <span class="price-num">{p.price}</span><span class="price-unit">円</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- 学生コース -->
    <div class="special-card">
      <div class="special-info">
        <span class="special-tag">学生限定</span>
        <h4 class="special-title">学生コース</h4>
        <p class="special-sub">クラリネット / 中学生・高校生・大学生</p>
        <p class="special-desc">部活動やコンクール対策、基礎力アップにおすすめのコースです。</p>
      </div>
      <div class="special-price-wrap">
        <span class="price-num">5,000</span><span class="price-unit">円</span>
        <span class="price-unit-sub">/ 月2回（30分）</span>
      </div>
    </div>

    <!-- ピアノ単発レッスン -->
    <h3 class="price-category price-category--mt">
      <span class="category-line" aria-hidden="true"></span>ピアノ 単発レッスン
    </h3>
    <div class="special-card">
      <div class="special-info">
        <span class="special-tag">大人の趣味の方へ</span>
        <h4 class="special-title">ピアノ レッスン</h4>
        <p class="special-sub">大人の趣味の方限定</p>
        <p class="special-desc">弾きたい曲を一曲から。お好きなタイミングでご利用いただける単発レッスンです。</p>
      </div>
      <div class="special-price-wrap">
        <span class="price-num">5,000</span><span class="price-unit">円</span>
        <span class="price-unit-sub">/ 1回（60分・単発）</span>
      </div>
    </div>

    <!-- 出張レッスン -->
    <h3 class="price-category price-category--mt">
      <span class="category-line" aria-hidden="true"></span>出張レッスン
      <span class="category-sub">（クラリネット・ピアノ共通）</span>
    </h3>
    <div class="special-card">
      <div class="special-info">
        <span class="special-tag">出張・共通</span>
        <h4 class="special-title">出張レッスン</h4>
        <p class="special-sub">対応エリア：さいたま市・東京都心部・他要相談</p>
        <p class="special-desc">ご自宅やスタジオへ伺います。クラリネット・ピアノのどちらにも対応いたします。</p>
      </div>
      <div class="special-price-wrap">
        <span class="price-num">8,000</span><span class="price-unit">円</span>
        <span class="price-unit-sub">/ 1時間（交通費込み）</span>
      </div>
    </div>

    <!-- ご案内 -->
    <div class="price-notes">
      <p class="notes-heading">ご案内</p>
      <ul class="notes-list">
        {notes.map(note => (
          <li><span class="notes-bullet" aria-hidden="true">—</span><span>{note}</span></li>
        ))}
      </ul>
    </div>

    <div class="price-cta">
      <a href="#contact" class="btn-primary">このプランで申し込む →</a>
    </div>
  </div>
</section>

<style>
  .price-section {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: var(--py) var(--px);
  }

  .price-header {
    text-align: center;
    margin-bottom: clamp(38px, 5vw, 56px);
  }

  .price-note {
    font-size: 14.5px;
    color: var(--text-faint);
    letter-spacing: 0.04em;
    margin: 4px 0 0;
  }

  /* ── カテゴリ見出し ── */
  .price-category {
    font-family: var(--font-serif-ja);
    font-weight: 600;
    font-size: 18px;
    color: var(--wine);
    letter-spacing: 0.1em;
    margin: 0 0 20px;
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .price-category--mt {
    margin-top: clamp(42px, 5vw, 58px);
  }

  .category-line {
    width: 24px;
    height: 1px;
    background: var(--wine);
    flex-shrink: 0;
  }

  .category-sub {
    font-size: 12px;
    color: var(--text-light);
    font-weight: 500;
    letter-spacing: 0.04em;
  }

  /* ── クラリネット料金グリッド ── */
  .clarinet-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: clamp(16px, 2vw, 24px);
  }

  .plan-card {
    background: var(--cream-light);
    border: 1px solid var(--border);
    padding: clamp(22px, 3vw, 30px);
  }

  .plan-duration {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-bottom: 18px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--border-light);
  }

  .duration-num {
    font-family: var(--font-serif-ja);
    font-weight: 600;
    font-size: 26px;
    color: var(--navy);
  }

  .duration-unit {
    font-size: 13px;
    color: var(--text-light);
  }

  .plan-rows {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .plan-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 10px;
  }

  .plan-label-wrap {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .plan-label {
    font-size: 14px;
    color: var(--text-lighter);
    font-weight: 500;
  }

  .plan-save {
    font-size: 11.5px;
    color: var(--wine);
    letter-spacing: 0.04em;
  }

  /* ── 特別コード（学生・ピアノ・出張）共通 ── */
  .special-card {
    margin-top: clamp(18px, 2.5vw, 26px);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 16px 28px;
    background: var(--cream-light);
    border: 1px solid var(--border);
    border-left: 3px solid var(--wine);
    padding: clamp(22px, 3vw, 30px);
  }

  .special-info {
    flex: 1 1 280px;
    min-width: 240px;
  }

  .special-tag {
    display: inline-block;
    background: var(--wine);
    color: var(--cream);
    font-size: 11px;
    letter-spacing: 0.12em;
    padding: 4px 11px;
    margin-bottom: 12px;
  }

  .special-title {
    font-family: var(--font-serif-ja);
    font-weight: 600;
    font-size: 21px;
    color: var(--navy);
    margin: 0 0 4px;
  }

  .special-sub {
    font-size: 12.5px;
    color: var(--text-light);
    letter-spacing: 0.04em;
    margin: 0 0 10px;
  }

  .special-desc {
    font-size: 13.5px;
    line-height: 1.95;
    color: var(--text-muted);
    margin: 0;
  }

  .special-price-wrap {
    font-family: var(--font-serif-ja);
    color: var(--navy);
    white-space: nowrap;
    display: flex;
    align-items: baseline;
    gap: 4px;
    flex-wrap: wrap;
  }

  /* ── 価格共通 ── */
  .price-num {
    font-family: var(--font-serif-ja);
    font-size: 23px;
    font-weight: 600;
    color: var(--navy);
  }

  .special-price-wrap .price-num {
    font-size: 30px;
  }

  .price-unit {
    font-size: 13px;
    color: var(--navy);
  }

  .price-unit-sub {
    font-size: 12.5px;
    color: var(--text-light);
    margin-left: 4px;
  }

  /* ── ご案内 ── */
  .price-notes {
    background: var(--cream-light);
    border: 1px solid var(--border);
    padding: clamp(22px, 3vw, 30px);
    margin-top: clamp(20px, 3vw, 28px);
  }

  .notes-heading {
    font-family: var(--font-serif-ja);
    font-weight: 600;
    font-size: 14px;
    color: var(--wine);
    letter-spacing: 0.1em;
    margin: 0 0 14px;
  }

  .notes-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 680px;
  }

  .notes-list li {
    display: flex;
    gap: 12px;
    font-size: 13.5px;
    line-height: 1.9;
    color: var(--text-muted);
  }

  .notes-bullet {
    color: var(--wine);
    flex-shrink: 0;
  }

  /* ── CTA ── */
  .price-cta {
    text-align: center;
    margin-top: clamp(36px, 5vw, 48px);
  }
</style>
