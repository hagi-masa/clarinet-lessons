---
/**
 * レッスンの流れセクション
 * 3ステップをカードで表示
 */

const steps = [
  {
    num: '01',
    title: 'お問い合わせ',
    desc: 'フォーム・メール・Instagram から、ご希望の楽器や時間帯をお知らせください。',
  },
  {
    num: '02',
    title: '体験・カウンセリング',
    desc: '現在のレベルや目標、楽器のご相談まで、ていねいにお伺いします。',
  },
  {
    num: '03',
    title: 'レッスン開始',
    desc: 'お一人おひとりに合わせたペースで、無理なく続けられるレッスンを。',
  },
];
---

<section class="flow-section">
  <div class="flow-inner">
    <div class="flow-header">
      <p class="sec-en">Flow</p>
      <h2 class="flow-title">レッスンの流れ</h2>
    </div>

    <div class="flow-cards">
      {steps.map(step => (
        <div class="flow-card">
          <span class="flow-num">{step.num}</span>
          <h3 class="flow-card-title">{step.title}</h3>
          <p class="flow-card-desc">{step.desc}</p>
        </div>
      ))}
    </div>

    <div class="flow-cta">
      <a href="#contact" class="btn-primary">まずは気軽にお問い合わせ →</a>
    </div>
  </div>
</section>

<style>
  .flow-section {
    /* 白背景 */
  }

  .flow-inner {
    max-width: var(--max-w-narrow);
    margin: 0 auto;
    padding: clamp(60px, 9vw, 110px) var(--px);
  }

  .flow-header {
    text-align: center;
    margin-bottom: clamp(40px, 6vw, 56px);
  }

  .flow-title {
    font-family: var(--font-serif-ja);
    font-weight: 600;
    font-size: clamp(26px, 4vw, 38px);
    color: var(--navy);
    margin: 0;
    letter-spacing: 0.06em;
  }

  /* ── カードグリッド ── */
  .flow-cards {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(20px, 3vw, 28px);
  }

  .flow-card {
    flex: 1 1 240px;
    min-width: 230px;
    background: var(--cream-light);
    border: 1px solid #e9e0cf;
    padding: clamp(26px, 3vw, 36px);
  }

  .flow-num {
    display: block;
    font-family: var(--font-serif-en);
    font-style: italic;
    font-size: 46px;
    color: var(--wine);
    line-height: 1;
    margin-bottom: 18px;
  }

  .flow-card-title {
    font-family: var(--font-serif-ja);
    font-weight: 600;
    font-size: 20px;
    color: var(--navy);
    margin: 0 0 12px;
  }

  .flow-card-desc {
    font-size: 14.5px;
    line-height: 2;
    color: var(--text-muted);
    margin: 0;
  }

  /* ── CTA ── */
  .flow-cta {
    text-align: center;
    margin-top: clamp(36px, 5vw, 48px);
  }
</style>
