---
// お問い合わせセクション
// フォーム送信時に mailto: でメールクライアントを開く

const CONTACT_EMAIL    = 'clarinet.yurie@gmail.com';
const INSTAGRAM_URL    = 'https://www.instagram.com/yreee22?igsh=NHo0c2NhMGN3bWpz';
const MAIL_SUBJECT     = encodeURIComponent('レッスンのお問い合わせ');
const MAIL_HREF        = `mailto:${CONTACT_EMAIL}?subject=${MAIL_SUBJECT}`;
---

<section id="contact" class="contact-section">
  <div class="contact-inner">
    <div class="contact-header">
      <p class="sec-en">Contact</p>
      <h2 class="sec-title" style="font-size: clamp(22px, 3.5vw, 36px);">
        レッスンのお申し込み・お問い合わせ
      </h2>
      <p class="contact-lead">
        体験レッスンやご相談もお気軽に。楽器のご購入前のご相談も承ります。
      </p>
    </div>

    <!-- お問い合わせフォーム（送信時 mailto: でメールクライアントを起動） -->
    <form class="contact-form" id="contact-form" novalidate>
      <div class="form-row">
        <label class="form-label">
          お名前 <span class="required">必須</span>
          <input
            type="text"
            name="name"
            placeholder="山田 花子"
            required
            class="form-input"
            autocomplete="name"
          />
        </label>
        <label class="form-label">
          メールアドレス <span class="required">必須</span>
          <input
            type="email"
            name="email"
            placeholder="example@mail.com"
            required
            class="form-input"
            autocomplete="email"
          />
        </label>
      </div>

      <label class="form-label">
        ご希望のコース
        <select name="course" class="form-select">
          <option>クラリネット（個人レッスン）</option>
          <option>クラリネット（学生限定コース）</option>
          <option>ピアノ（大人の趣味・単発）</option>
          <option>出張レッスン</option>
          <option>まだ決めていない / 相談したい</option>
        </select>
      </label>

      <label class="form-label">
        メッセージ
        <textarea
          name="message"
          rows="5"
          placeholder="ご質問・ご希望の曜日や時間帯など、お気軽にどうぞ。"
          class="form-textarea"
        ></textarea>
      </label>

      <button type="submit" class="form-submit btn-primary">
        送信する
      </button>
      <p class="form-note">
        ※「送信する」を押すと、ご入力内容を本文にしたメール作成画面が開きます。
      </p>
    </form>

    <!-- 直接連絡先 -->
    <div class="contact-direct">
      <p class="direct-label">または、直接ご連絡ください</p>
      <div class="direct-btns">
        <a href={MAIL_HREF} class="btn-primary direct-mail">
          メールで問い合わせる
        </a>
        <a
          href={INSTAGRAM_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-outline"
        >
          Instagram
        </a>
      </div>
    </div>
  </div>
</section>

<!-- フォーム送信処理（メールクライアントを起動） -->
<script lang="ts">
  const form = document.getElementById('contact-form');

  if (!(form instanceof HTMLFormElement)) {
    throw new Error('お問い合わせフォームが見つかりませんでした。');
  }

  form.addEventListener('submit', (e) => {
    e.preventDefault();

    const data = new FormData(form);
    const get = (key: string) => ((data.get(key) ?? '').toString()).trim();

    const name    = get('name');
    const email   = get('email');
    const course  = get('course');
    const message = get('message');

    // バリデーション
    if (!name || !email) {
      alert('お名前とメールアドレスをご入力ください。');
      return;
    }

    // メール本文を組み立て
    const body = [
      `お名前: ${name}`,
      `メールアドレス: ${email}`,
      `ご希望のコース: ${course}`,
      '',
      message,
    ].join('\n');

    const to      = 'clarinet.yurie@gmail.com';
    const subject = encodeURIComponent('レッスンのお問い合わせ');
    const bodyEnc = encodeURIComponent(body);

    window.location.href = `mailto:${to}?subject=${subject}&body=${bodyEnc}`;
  });
</script>

<style>
  .contact-section {
    /* 白背景 */
    color: var(--text);
  }

  .contact-inner {
    max-width: var(--max-w-text);
    margin: 0 auto;
    padding: var(--py) var(--px);
  }

  .contact-header {
    text-align: center;
    margin-bottom: clamp(34px, 5vw, 48px);
  }

  .contact-lead {
    font-size: 15px;
    line-height: 2;
    color: var(--text-muted);
    max-width: 30em;
    margin: 0 auto;
  }

  /* ── フォーム ── */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .form-row {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
  }

  .form-row .form-label {
    flex: 1 1 220px;
    min-width: 200px;
  }

  .form-label {
    display: flex;
    flex-direction: column;
    gap: 7px;
    font-size: 13px;
    letter-spacing: 0.06em;
    color: #6a6258;
  }

  .required {
    color: var(--wine);
    font-size: 11px;
    margin-left: 4px;
  }

  .form-input,
  .form-select,
  .form-textarea {
    width: 100%;
    padding: 13px 14px;
    border: 1px solid #d9cdb6;
    background: var(--cream-light);
    color: var(--text);
    font-size: 15px;
    border-radius: 2px;
    transition: border-color 0.2s, box-shadow 0.2s;
    outline: none;
  }

  .form-input:focus,
  .form-select:focus,
  .form-textarea:focus {
    border-color: var(--wine);
    box-shadow: 0 0 0 2px rgba(110, 42, 54, 0.15);
  }

  .form-textarea {
    resize: vertical;
    line-height: 1.8;
    min-height: 120px;
  }

  .form-submit {
    margin-top: 6px;
    justify-content: center;
    font-size: 16px;
    letter-spacing: 0.08em;
    padding: 17px;
    width: 100%;
  }

  .form-note {
    font-size: 12px;
    color: var(--text-light);
    text-align: center;
    margin: 4px 0 0;
  }

  /* ── 直接連絡先 ── */
  .contact-direct {
    margin-top: clamp(28px, 4vw, 40px);
    padding-top: clamp(26px, 3vw, 34px);
    border-top: 1px solid var(--border);
    text-align: center;
  }

  .direct-label {
    font-size: 13px;
    color: var(--text-light);
    letter-spacing: 0.08em;
    margin: 0 0 18px;
  }

  .direct-btns {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
  }

  .direct-mail {
    font-size: 14px;
    padding: 13px 26px;
  }
</style>
