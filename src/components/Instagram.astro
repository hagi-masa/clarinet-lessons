---
// Instagram セクション
//
// 実際の投稿画像をグリッドで表示するには Behold.so を使用します。
//
// 【設定手順】
// 1. https://behold.so にアクセスしてアカウント作成（無料プランあり）
// 2. Instagram アカウント @yreee22 を連携する
// 3. ダッシュボードで「Feed」を作成し、Feed ID（例: ABCDE12345）をコピー
// 4. 下記 BEHOLD_FEED_ID にその ID を貼り付ける（例: 'ABCDE12345'）
//
// BEHOLD_FEED_ID が空の場合はプレースホルダーグリッドを表示します。

const BEHOLD_FEED_ID   = 'wCR9k9BbcVI5OZMvoAwA';   // ← Behold.so の Feed ID を入れる
const INSTAGRAM_URL    = 'https://www.instagram.com/yreee22?igsh=NHo0c2NhMGN3bWpz';
const INSTAGRAM_HANDLE = '@yreee22';

// Behold.so を使用するかどうか
const useBeholdWidget = BEHOLD_FEED_ID.length > 0;
---

<section id="instagram" class="insta-section">
  <div class="insta-inner">
    <div class="insta-header">
      <div>
        <p class="sec-en">Instagram</p>
        <h2 class="insta-title">演奏と日々のこと</h2>
      </div>
      <a
        href={INSTAGRAM_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="insta-follow btn-outline"
        aria-label="Instagram をフォロー（新しいタブで開きます）"
      >
        Instagram をフォロー →
      </a>
    </div>

    {useBeholdWidget ? (
      /* ── Behold.so ウィジェット（実際の Instagram 画像を表示） ── */
      <div class="behold-wrap">
        <behold-widget feed-id={`${BEHOLD_FEED_ID}`}></behold-widget>
      </div>
    ) : (
      /* ── プレースホルダーグリッド（Behold未設定時） ── */
      <div class="insta-placeholder">
        <div class="insta-grid" aria-label="Instagram 投稿グリッド（プレースホルダー）">
          {Array.from({ length: 6 }).map((_, i) => (
            <a
              href={INSTAGRAM_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="insta-tile"
              aria-label={`Instagram 投稿 ${i + 1}（${INSTAGRAM_HANDLE}）`}
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="28"
                height="28"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1"
                aria-hidden="true"
                class="insta-icon"
              >
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                <circle cx="12" cy="12" r="5"></circle>
                <circle cx="17.5" cy="6.5" r="1.2" fill="currentColor"></circle>
              </svg>
            </a>
          ))}
        </div>
        <div class="placeholder-note">
          <p>
            <a href={INSTAGRAM_URL} target="_blank" rel="noopener noreferrer" class="insta-handle">{INSTAGRAM_HANDLE}</a>
            で最新の演奏・日常を発信中
          </p>
        </div>
      </div>
    )}

    <p class="insta-caption">
      演奏動画や日常の様子を発信しています。<br>
      フォローしてご覧ください。
    </p>
  </div>
</section>

<!-- behold-widget 要素がある場合のみ Behold.so スクリプトを動的に読み込む -->
<!-- is:inline でこの位置（section直後）にインライン配置し、DOM解析後に実行 -->
<script is:inline>
  if (document.querySelector('behold-widget')) {
    var s = document.createElement('script');
    s.type = 'module';
    s.src = 'https://w.behold.so/widget.js';
    document.head.append(s);
  }
</script>

<style>
  .insta-section {
    /* 白背景 */
  }

  .insta-inner {
    max-width: var(--max-w-narrow);
    margin: 0 auto;
    padding: clamp(56px, 8vw, 100px) var(--px);
  }

  /* ── ヘッダー行 ── */
  .insta-header {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: flex-end;
    gap: 18px;
    margin-bottom: clamp(28px, 4vw, 40px);
  }

  .insta-title {
    font-family: var(--font-serif-ja);
    font-weight: 600;
    font-size: clamp(24px, 4vw, 36px);
    color: var(--navy);
    margin: 0;
    letter-spacing: 0.06em;
  }

  .insta-follow {
    font-size: 14px;
    padding: 12px 24px;
    white-space: nowrap;
  }

  /* ── Behold ウィジェット ── */
  .behold-wrap {
    width: 100%;
  }

  /* ── プレースホルダーグリッド ── */
  .insta-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(8px, 1.4vw, 14px);
  }

  @media (max-width: 480px) {
    .insta-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .insta-tile {
    position: relative;
    aspect-ratio: 1 / 1;
    background: repeating-linear-gradient(
      45deg,
      #ece2cd,
      #ece2cd 11px,
      #f3ebda 11px,
      #f3ebda 22px
    );
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    color: #c4b49a;
    transition: opacity 0.25s, color 0.25s;
  }

  .insta-tile:hover {
    opacity: 0.8;
    color: var(--wine);
  }

  .placeholder-note {
    text-align: center;
    margin-top: 18px;
    font-size: 14px;
    color: var(--text-muted);
  }

  /* ── キャプション ── */
  .insta-caption {
    text-align: center;
    margin-top: clamp(22px, 3vw, 30px);
    font-size: 14px;
    line-height: 2;
    color: var(--text-muted);
  }

  .insta-handle {
    color: var(--wine);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
